<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="admin/tool/coursebulkactions/db" VERSION="20260205" COMMENT="XMLDB file for Moodle admin/tool/coursebulkactions/db"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="tool_coursebulkactions" COMMENT="Saved searches">
      <FIELDS>
        <FIELD NAME="id" SEQUENCE="true" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="title" SEQUENCE="false" TYPE="char" LENGTH="100" NOTNULL="true"/>
        <FIELD NAME="description" SEQUENCE="false" TYPE="text" NOTNULL="false" />
        <FIELD NAME="criteria" SEQUENCE="false" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="usermodified" SEQUENCE="false" TYPE="int" NOTNULL="true" LENGTH="10" UNSIGNED="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="tool_coursebulkactions_queue" COMMENT="Queue for course bulk actions, also serves as a log">
      <FIELDS>
        <FIELD NAME="id" SEQUENCE="true" TYPE="int" LENGTH="10" NOTNULL="true" />
        <FIELD NAME="courseid" SEQUENCE="false" TYPE="int" LENGTH="10" NOTNULL="true" />
        <FIELD NAME="fullname" TYPE="char" LENGTH="254" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="shortname" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="action" SEQUENCE="false" TYPE="char" LENGTH="25" NOTNULL="true" DEFAULT="delete" />
        <FIELD NAME="status" SEQUENCE="false" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="usermodified" SEQUENCE="false" TYPE="int" NOTNULL="true" LENGTH="10" UNSIGNED="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id" />
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id" />
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseidaction" UNIQUE="true" FIELDS="courseid,action" />
        <INDEX NAME="actionstatus" UNIQUE="false" FIELDS="action,status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
